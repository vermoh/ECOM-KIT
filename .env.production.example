# Database
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=ecom_platform
DATABASE_URL=postgresql://ecom_user:<change-me>@postgres:5432/ecom_platform

# Auth & Security
JWT_SECRET=<change-me-32-chars>
CSV_SERVICE_TOKEN=<change-me-32-chars>
ENCRYPTION_KEY=<change-me-64-hex-chars>

# External APIs (optional)
OPENROUTER_API_KEY=

# S3 (MinIO)
S3_BUCKET=csv-uploads
S3_ACCESS_KEY=<change-me>
S3_SECRET_KEY=<change-me>

# URLs
WEB_ORIGIN=http://YOUR_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_IP:4000
NEXT_PUBLIC_CSV_API_URL=http://YOUR_IP:4001
